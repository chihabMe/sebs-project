# Development values. Copy to .env for local Docker development.
APP_DOMAIN=eventify-dev.local.home
ADMIN_DOMAIN=eventify-admin-dev.local.home
API_DOMAIN=eventify-api-dev.local.home
LOGS_DOMAIN=eventify-logs-dev.local.home
WEB_APP_URL=https://eventify-dev.local.home
ADMIN_APP_URL=https://eventify-admin-dev.local.home
FRONTEND_URLS=https://eventify-dev.local.home,https://eventify-admin-dev.local.home
FIRESTORE_PROJECT_ID=eventify-dev
FIRESTORE_EMULATOR_HOST=firestore-dev:8080
JWT_SECRET=supersecretfallback
JWT_REFRESH_SECRET=refreshsecretfallback
RESEND_API_KEY=
MAIL_FROM="Eventify <onboarding@resend.dev>"
TRAEFIK_ACME_EMAIL=admin@example.com
