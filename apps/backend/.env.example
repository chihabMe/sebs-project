PORT=4000
FRONTEND_URLS="http://localhost:5173,http://localhost:5174,http://localhost:3000"
FIRESTORE_PROJECT_ID="your-google-cloud-project-id"
# Local emulator example: FIRESTORE_EMULATOR_HOST="127.0.0.1:8085"
# Production VM example: GOOGLE_APPLICATION_CREDENTIALS="/run/secrets/firestore-service-account.json"
# Alternative production secret: FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
JWT_SECRET="replace-with-a-long-random-secret"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-secret"
RESEND_API_KEY=""
